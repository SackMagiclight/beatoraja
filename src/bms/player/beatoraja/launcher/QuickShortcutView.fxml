<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.geometry.Insets?>
<VBox xmlns="http://javafx.com/javafx/8.0.65" xmlns:fx="http://javafx.com/fxml/1" fx:controller="bms.player.beatoraja.launcher.QuickShortcutView">
	<padding>
		<Insets left="10.0" top="10.0" />
	</padding>
    <HBox prefHeight="37.0" prefWidth="723.0">
        <Button fx:id="player1Button" prefWidth="100.0" text="Set 1P" onAction="#setPlayer1" />
        <Button fx:id="player2Button" prefWidth="100.0" text="Set 2P" onAction="#setPlayer2" />
        <Label prefHeight="34.0" prefWidth="45.0" text="7KEYS:" /><Label fx:id="nowControllerName" prefHeight="34.0" prefWidth="200.0" />
    </HBox>
    <HBox prefHeight="37.0" prefWidth="723.0">
    	<Label prefHeight="24.0" prefWidth="120.0" text="BM CONTROLLER" />
    </HBox>
    <HBox prefHeight="37.0" prefWidth="723.0">
    	<Label prefHeight="24.0" prefWidth="30.0" text="1P" />
        <ComboBox fx:id="player1ControllerName" prefHeight="24.0" prefWidth="200.0" />
        <Label prefHeight="24.0" prefWidth="30.0" text="2P" />
        <ComboBox fx:id="player2ControllerName" prefHeight="24.0" prefWidth="200.0" />
    </HBox>
    <HBox prefHeight="37.0" prefWidth="723.0">
    	<Label prefHeight="24.0" prefWidth="40.0" text="SKIN" />
    </HBox>
    <HBox prefHeight="37.0" prefWidth="723.0">
    	<Label prefHeight="24.0" prefWidth="60.0" text="1P OPTION" />
        <ComboBox fx:id="player1SkinName7Keys" prefHeight="24.0" prefWidth="200.0" onAction="#setPlayer1SkinName7Keys"/>
        <ComboBox fx:id="player1SkinValue7Keys" prefHeight="24.0" prefWidth="200.0"/>
    </HBox>
    <HBox prefHeight="37.0" prefWidth="723.0">
    	<Label prefHeight="24.0" prefWidth="60.0" text="2P OPTION" />
        <ComboBox fx:id="player2SkinName7Keys" prefHeight="24.0" prefWidth="200.0" onAction="#setPlayer2SkinName7Keys"/>
        <ComboBox fx:id="player2SkinValue7Keys" prefHeight="24.0" prefWidth="200.0"/>
    </HBox>
    <HBox prefHeight="37.0" prefWidth="723.0">
    </HBox>
</VBox>
